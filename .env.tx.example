# 交易配置：swap-via-okx.js 用，全部走配置文件，没有 CLI 参数。

# OKX Onchain OS API 凭证（web3.okx.com Developer Portal 申请）
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
OKX_API_PROJECT=

# 委托方（付款方）EOA 私钥，会通过 EIP-7702 委托到 SmartWallet。
# 和 .env.common 里的 PRIVATE_KEY（广播/admin 账号）是两个不同账号。
EOA_PRIVATE_KEY=

# 交易方向：buy（花 fromToken 买 toToken）或 sell（卖 fromToken 换 toToken）。
# 决定手续费从哪个代币扣：buy 扣 fromToken，sell 扣 toToken。
SWAP_SIDE=

# 卖出 / 买入的代币合约地址。原生代币（ETH）用 OKX 约定的占位地址
# 0xEeeeeEeeeEeEeeEeEeEeeEEEeeeeEeeeeeeeEEeE（不是 address(0)，脚本内部会做转换）。
FROM_TOKEN_ADDRESS=
TO_TOKEN_ADDRESS=

# 卖出数量，带精度的最小单位（比如 USDC 6 位精度，1 USDC 填 1000000）。
AMOUNT=

# 滑点百分比，0-100，比如 0.5 代表 0.5%。
SLIPPAGE_PERCENT=

# 买入资产的收款地址，留空则默认等于委托方 EOA 自己。
SWAP_RECEIVER_ADDRESS=

# 手续费百分比：buy 按 fromToken 金额算，sell 按 OKX 返回的 minReceiveAmount 算
# （用 minReceiveAmount 而不是预估到手量，防止滑点导致手续费比实际到账还多）。
FEE_PERCENT=

# 手续费收款地址，必须已经在 WalletRegistry.addGasReceives() 白名单里，否则链上会 revert。
GAS_RECEIVE_ADDRESS=

# true 才会真实广播交易；留空/其他值都是 dry-run（构造交易 + eth_call 模拟，不上链）。
BROADCAST=

# 可选，手动覆盖广播 gas limit；不填则用 eth_estimateGas 真实预估（同样带上 authorizationList）+ 30% 余量。
TX_GAS_LIMIT=
