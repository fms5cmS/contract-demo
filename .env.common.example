# 通用配置：签名账号 + 目标网络 RPC / chainId，部署和后续交易脚本共用

# 签名账号私钥（部署、发交易都用这个）
PRIVATE_KEY=

# 目标链 RPC（当前只对接一条链，切链改这一个值就够，不用跨链）
RPC_URL=
CHAIN_ID=



# 当前目标链上已部署的 SmartWallet 实现合约地址（swap-via-okx.js 用来做 EIP-7702 委托目标）
SMART_WALLET_ADDRESS=

# swap 代付方（垫付 gas 的 admin/relayer）私钥，独立于 PRIVATE_KEY（部署账号）。
# 留空则 fallback 用 PRIVATE_KEY。这个地址必须已经在 WalletRegistry.addAdmins() 白名单里，
# 否则 executeBatchByAdmin 会 revert "Not an authorized admin"。
SPONSOR_PRIVATE_KEY=
